{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/openai", "destination": "/api/openai" },
    { "source": "/api/proxy", "destination": "/api/proxy" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
